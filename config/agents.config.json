  "risk": {
    "scoringFormula": {
      "note": "Risk Score 0-100. Apply to every vendor in Top 20 MTD list.",
      "factor1_targetDeviation": {
        "maxPoints": 40,
        "formula": "min(40, ((vendor_vfr_pct - cluster_target_pct) / cluster_target_pct * 100) * 0.8)",
        "note": "Only applies when vendor VFR is above cluster target"
      },
      "factor2_vendorFaultCases": {
        "maxPoints": 30,
        "formula": "min(30, (vendor_vfos_mtd / 500) * 6)"
      },
      "factor3_orderVolume": {
        "maxPoints": 20,
        "formula": "min(20, (vendor_net_orders_mtd / 10000) * 4)"
      },
      "factor4_lostGmv": {
        "maxPoints": 10,
        "formula": "min(10, (vendor_vfos_mtd * 180) / 20000)",
        "note": "Lost GMV proxy: VFOs x EGP 180 avg order value"
      }
    },
    "thresholds": {
      "low": {
        "min": 0,
        "max": 25,
        "action": "No action needed"
      },
      "medium": {
        "min": 26,
        "max": 50,
        "action": "Monitor closely"
      },
      "high": {
        "min": 51,
        "max": 75,
        "action": "Requires immediate review"
      },
      "critical": {
        "min": 76,
        "max": 100,
        "action": "Escalation required"
      }
    },
    "escalationThreshold": 75,
    "reviewThreshold": 50
  },
  "performance": {
    "thresholds": {
      "minDailyOrders": 10,
      "minDailyRevenue": 500,
      "minAverageOrderValue": 100,
      "maxDeclinePercent": 20
    }
  },
